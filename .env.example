# Required: your full Cookie header from suno.com (must contain __client)
# How to get it:
#   1. Log in to https://suno.com in your browser
#   2. Open DevTools (F12) -> Network tab
#   3. Refresh the page
#   4. Click any request to suno.com -> Headers -> Request Headers
#   5. Copy the entire value of the "Cookie" header (it will be a long string)
SUNO_COOKIE=

# Optional: set to "browser" to force CloakBrowser path for generation
# Set to "api" to force the cookie/JWT API path (fails fast if captcha required)
# Default "auto" tries API first, falls back to browser on captcha
SUNO_GENERATION_MODE=auto

# Optional: run the browser headed (visible) so you can click through hCaptcha manually
# Default true the first time, then switch to false once your fingerprint is trusted
SUNO_BROWSER_HEADLESS=false

# Optional: default model for generation.
# Known internal identifiers:
#   chirp-v3-5  (v3.5)        chirp-auk / chirp-bluejay (v4.5)
#   chirp-crow  (v5)          chirp-fenix (v5.5 - latest as of May 2026)
SUNO_DEFAULT_MODEL=chirp-fenix
